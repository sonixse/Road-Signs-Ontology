        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>https://example.org/roadsigns#VColours</IRI>
        <Literal xml:lang="en">Colour meanings
        Black: Symbols and text
        Blue: Background of mandatory signs, information signs
        Green: Motorway information signs
        Orange: Temporary roadwork signs (some countries)
        Red: Borders of warning and prohibitory signs
        White: Background of prohibitory/warning signs
        Yellow: Alternative background for warning signs (some countries)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>https://example.org/roadsigns#VColours</IRI>
        <Literal xml:lang="en">Strictly closed colour vocabulary of Vienna Convention Annex 1.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>https://example.org/roadsigns#VShape</IRI>
        <Literal xml:lang="en">Shape meanings
            Circle: Prohibitory and mandatory signs
            Inverted triangle: Yield / Give Way sign
            Octagon: STOP sign only
            Rectangle / Square: Information, guidance, and service signs
            Triangle: Warning signs (hazards ahead)

Not Vienna Standard shapes
            Diamond: 4-sided tilted square used in some countries for warning signs 
            Pentagon: 5-sided shape mainly used in the U.S. for school crossing signs</Literal>
    </AnnotationAssertion>

    <!-- http://example.org/roadsigns-assignment#AnimalHazardSign -->

    <owl:Class rdf:about="http://example.org/roadsigns-assignment#AnimalHazardSign">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/sonia/ontologies/2026/4/untitled-ontology-46#DangerWarningSign"/>
    </owl:Class>
    


    <!-- http://example.org/roadsigns-assignment#DomesticAnimalCrossingSign -->

    <owl:Class rdf:about="http://example.org/roadsigns-assignment#DomesticAnimalCrossingSign">
        <rdfs:subClassOf rdf:resource="http://example.org/roadsigns-assignment#AnimalHazardSign"/>
        <rdfs:comment xml:lang="en">A danger warning sign indicating a section of the road where livestock or farm animals are likely to be encountered. This sign warns of animals such as cattle, sheep, or goats that may be crossing the road under the supervision of a herder or having escaped from nearby grazing land.</rdfs:comment>
    </owl:Class>
    


    <!-- http://example.org/roadsigns-assignment#EnvironmentContext -->

    <owl:Class rdf:about="http://example.org/roadsigns-assignment#EnvironmentContext"/>
    


    <!-- http://example.org/roadsigns-assignment#EquestriansCrossingSign -->

    <owl:Class rdf:about="http://example.org/roadsigns-assignment#EquestriansCrossingSign">
        <rdfs:subClassOf rdf:resource="http://example.org/roadsigns-assignment#AnimalHazardSign"/>
        <rdfs:comment xml:lang="en">A danger warning sign indicating a section of the road frequently used by horse riders (equestrians). It warns motorists of the potential presence of horses with riders crossing or moving along the carriageway, requiring reduced speed and caution to avoid startling the animals.</rdfs:comment>
    </owl:Class>
    


    <!-- http://example.org/roadsigns-assignment#GeographicContext -->

    <owl:Class rdf:about="http://example.org/roadsigns-assignment#GeographicContext"/>
    


    <!-- http://example.org/roadsigns-assignment#OtherHazardCrossings -->

    <owl:Class rdf:about="http://example.org/roadsigns-assignment#OtherHazardCrossings">
        <rdfs:subClassOf rdf:resource="http://example.org/roadsigns-assignment#AnimalHazardSign"/>
    </owl:Class>
    


    <!-- http://example.org/roadsigns-assignment#TrailCrossingSign -->

    <owl:Class rdf:about="http://example.org/roadsigns-assignment#TrailCrossingSign">
        <rdfs:subClassOf rdf:resource="http://example.org/roadsigns-assignment#AnimalHazardSign"/>
        <rdfs:comment xml:lang="en">A danger warning sign indicating a point where a recreational or pack-animal trail intersects with a public road. This includes crossings for hikers, mountain bikers, or led animals (such as pack mules). It indicates a higher probability of non-motorized traffic emerging from non-visible paths.</rdfs:comment>
    </owl:Class>
    


    <!-- http://example.org/roadsigns-assignment#WildAnimalCrossingSign -->

    <owl:Class rdf:about="http://example.org/roadsigns-assignment#WildAnimalCrossingSign">
        <rdfs:subClassOf rdf:resource="http://example.org/roadsigns-assignment#AnimalHazardSign"/>
        <rdfs:comment xml:lang="en">A danger warning sign alerting drivers to a stretch of road passing through areas with high populations of free-roaming wildlife. It indicates a risk of large wild animals (such as deer, moose, or elk) suddenly entering the roadway, especially during dawn, dusk, or mating seasons</rdfs:comment>
        <rdfs:label xml:lang="en">WildAnimalCrossingSign ⊑ AnimalCollisionRisk : 0.90</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/sonia/ontologies/2026/4/untitled-ontology-46#AnimalCollisionRisk -->

    <owl:Class rdf:about="http://www.semanticweb.org/sonia/ontologies/2026/4/untitled-ontology-46#AnimalCollisionRisk"/>
    


    <!-- http://www.semanticweb.org/sonia/ontologies/2026/4/untitled-ontology-46#AustralianContext -->

    <owl:Class rdf:about="http://www.semanticweb.org/sonia/ontologies/2026/4/untitled-ontology-46#AustralianContext">
        <owl:equivalentClass>

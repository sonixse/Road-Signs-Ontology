    <!-- http://www.semanticweb.org/sonia/ontologies/2026/4/untitled-ontology-46#hasShape -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/sonia/ontologies/2026/4/untitled-ontology-46#hasShape">
        <rdfs:range rdf:resource="http://www.semanticweb.org/sonia/ontologies/2026/4/untitled-ontology-46#Shape"/>
        <rdfs:comment xml:lang="en">Associates a road sign with its geometric shape. Functional: each sign has exactly one shape.</rdfs:comment>
        <rdfs:label xml:lang="en">Has shape</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/sonia/ontologies/2026/4/untitled-ontology-46#hasSymbol -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/sonia/ontologies/2026/4/untitled-ontology-46#hasSymbol">

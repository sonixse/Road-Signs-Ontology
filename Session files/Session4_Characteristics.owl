            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Section A of the Vienna Convention. Triangular signs (Model A^a) or diamond-shaped signs (Model A^b) that warn of hazards ahead. Background white or yellow, border red.</rdfs:comment>
        <rdfs:label xml:lang="en">Danger Warning Sign</rdfs:label>
    </owl:Class>
    



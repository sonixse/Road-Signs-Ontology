    </owl:Class>
    


    <!-- https://example.org/roadsigns#RightOfWayPrioritySign -->

    <owl:Class rdf:about="https://example.org/roadsigns#RightOfWayPrioritySign">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://example.org/roadsigns#RoadSign"/>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://example.org/roadsigns#hasBackgroundColour"/>
                                <owl:hasValue rdf:resource="https://example.org/roadsigns#Orange"/>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="https://example.org/roadsigns#hasBackgroundColour"/>
                                <owl:hasValue rdf:resource="https://example.org/roadsigns#Yellow"/>
                            </owl:Restriction>
                        </owl:unionOf>
                    </owl:Class>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/roadsigns#hasBorderColour"/>
                        <owl:hasValue rdf:resource="https://example.org/roadsigns#White"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/roadsigns#hasShape"/>
                        <owl:hasValue rdf:resource="https://example.org/roadsigns#Diamond"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#PrioritySign"/>
    </owl:Class>
    



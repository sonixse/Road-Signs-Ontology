    <!-- https://example.org/roadsigns#WeightLimitSign -->

    <owl:Class rdf:about="https://example.org/roadsigns#WeightLimitSign">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://example.org/roadsigns#ProhibitorySign"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/roadsigns#hasWeightLimitValue"/>
                        <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#DimensionMassProhibitorySign"/>
        <rdfs:comment xml:lang="en">Restricts the maximum gross vehicle weight permitted.</rdfs:comment>
        <rdfs:label xml:lang="en">Weight Limit Sign</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/roadsigns#WeightLimitWithTrucksSign -->

    <owl:Class rdf:about="https://example.org/roadsigns#WeightLimitWithTrucksSign">
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#WeightLimitSign"/>
    </owl:Class>
    



    </owl:Class>
    


    <!-- https://example.org/roadsigns#RoadworkSign -->

    <owl:Class rdf:about="https://example.org/roadsigns#RoadworkSign">
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#RoadSurfaceHazardSign"/>
        <rdfs:comment xml:lang="en">A16: warns of roadworks ahead.</rdfs:comment>
        <rdfs:label xml:lang="en">Road Work Sign</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/roadsigns#RoundaboutSign -->

    <owl:Class rdf:about="https://example.org/roadsigns#RoundaboutSign">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://example.org/roadsigns#RoundaboutSign"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/roadsigns#hasSymbol"/>
                        <owl:someValuesFrom rdf:resource="https://example.org/roadsigns#RoundaboutSymbol"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#DirectionMandatorySign"/>
        <rdfs:comment xml:lang="en">Defined by the Vienna Convention as Sign D, 3. Notifies drivers they must follow the direction indicated by the arrows in a circular movement. 

Note: In Right-Hand Traffic (RHT) countries, circulation is anti-clockwise. Per Article 8, in Left-Hand Traffic (LHT) countries like Ireland, the symbol is mirrored to indicate clockwise circulation.</rdfs:comment>
        <rdfs:label xml:lang="en">Roundabout Sign</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/roadsigns#RoundaboutSymbol -->

    <owl:Class rdf:about="https://example.org/roadsigns#RoundaboutSymbol">
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#DirectionSymbol"/>
    </owl:Class>
    



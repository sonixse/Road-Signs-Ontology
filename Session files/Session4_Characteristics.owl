    <!-- https://example.org/roadsigns#VColours -->

    <owl:Class rdf:about="https://example.org/roadsigns#VColours">
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#Colour"/>
        <rdfs:comment xml:lang="en">Colour meanings
        Black: Symbols and text
        Blue: Background of mandatory signs, information signs
        Green: Motorway information signs
        Orange: Temporary roadwork signs (some countries)
        Red: Borders of warning and prohibitory signs
        White: Background of prohibitory/warning signs
        Yellow: Alternative background for warning signs (some countries)</rdfs:comment>
        <rdfs:label xml:lang="en">Strictly closed colour vocabulary of Vienna Convention Annex 1.</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/roadsigns#VShape -->

    <owl:Class rdf:about="https://example.org/roadsigns#VShape">
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#Shape"/>
        <rdfs:comment xml:lang="en">Shape meanings
            Circle: Prohibitory and mandatory signs
            Inverted triangle: Yield / Give Way sign
            Octagon: STOP sign only
            Rectangle / Square: Information, guidance, and service signs
            Triangle: Warning signs (hazards ahead)

Not Vienna Standard shapes
            Diamond: 4-sided tilted square used in some countries for warning signs 
            Pentagon: 5-sided shape mainly used in the U.S. for school crossing signs</rdfs:comment>
        <rdfs:label xml:lang="en">Strictly closed shape vocabulary of Vienna Convention Annex 1.</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/roadsigns#VehicleClassComplementarySign -->

    <owl:Class rdf:about="https://example.org/roadsigns#VehicleClassComplementarySign">
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#ComplementarySign"/>
    </owl:Class>
    



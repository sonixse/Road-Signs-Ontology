    <!-- https://example.org/roadsigns#YieldPrioritySign -->

    <owl:Class rdf:about="https://example.org/roadsigns#YieldPrioritySign">
        <owl:equivalentClass rdf:resource="https://example.org/roadsigns#regulatory--yield--g1"/>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://example.org/roadsigns#RoadSign"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/roadsigns#hasBackgroundColour"/>
                        <owl:hasValue rdf:resource="https://example.org/roadsigns#White"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/roadsigns#hasBorderColour"/>
                        <owl:hasValue rdf:resource="https://example.org/roadsigns#Red"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/roadsigns#hasShape"/>
                        <owl:hasValue rdf:resource="https://example.org/roadsigns#InvertedTriangle"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#PrioritySign"/>
        <rdfs:comment xml:lang="en">B1/Give Way: inverted triangle, white/yellow background, red border.</rdfs:comment>
        <rdfs:label xml:lang="en">Give Way (Yield) Sign</rdfs:label>
    </owl:Class>
    



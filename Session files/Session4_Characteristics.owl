<?xml version="1.0"?>
<rdf:RDF xmlns="https://example.org/roadsigns#"
     xml:base="https://example.org/roadsigns"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:roadsigns="https://example.org/roadsigns#">
    <owl:Ontology rdf:about="https://example.org/roadsigns">
        <owl:versionIRI rdf:resource="https://example.org/roadsigns/4.0"/>
        <rdfs:comment xml:lang="en">Builds on Sessions 1-3 (full hierarchy + object/data properties).
            Adds:

            (A) Visual Axioms (Necessary Conditions) via rdfs:subClassOf + 
               owl:someValues for DangerWarningSign, ProhibitorySign, MandatorySign + owl:hasValue 
               when a property links to a specific individual, such as a fixed color or shape. 

            (B) Defined Classes (Necessary and Sufficient Conditions) via owl:equivalentClass
                for MaximumSpeedLimitSign, StopPrioritySign, WeightLimitSign.

All class names, object-property names, and data-property names are preserved
verbatim from Sessions 1-3. New Session-4 axioms are annotated with [S4].
Base IRI: https://example.org/roadsigns#
Vienna Convention on Road Signs and Signals (Part I, Annex 1).
Aligned with Mapillary Traffic Sign Dataset (MTSD) class labels.</rdfs:comment>
        <rdfs:label xml:lang="en">Road Signs Ontology — Session 4: Description Logic (DL) Restrictions Enhancement.</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://example.org/roadsigns#appliesTo -->

    <owl:ObjectProperty rdf:about="https://example.org/roadsigns#appliesTo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#RoadSign"/>
        <rdfs:range rdf:resource="https://example.org/roadsigns#RoadUser"/>
        <rdfs:comment xml:lang="en">Indicates which category of road user is subject to this sign.</rdfs:comment>
        <rdfs:label xml:lang="en">Applies to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/roadsigns#classifiedAs -->

    <owl:ObjectProperty rdf:about="https://example.org/roadsigns#classifiedAs">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#TrafficSignObject"/>
        <rdfs:range rdf:resource="https://example.org/roadsigns#RoadSign"/>
        <rdfs:comment xml:lang="en">Maps a raw detection to its formal semantic class.
Links a MTSD traffic sign object annotation to its corresponding ontology class.</rdfs:comment>
        <rdfs:label xml:lang="en">Classified as</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/roadsigns#depictsObject -->

    <owl:ObjectProperty rdf:about="https://example.org/roadsigns#depictsObject">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#Image"/>
        <rdfs:range rdf:resource="https://example.org/roadsigns#TrafficSignObject"/>
        <rdfs:comment xml:lang="en">Links an image to the abstract concept of a sign.</rdfs:comment>
        <rdfs:label xml:lang="en">Vienna Convention Mapping</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/roadsigns#hasBackgroundColour -->

    <owl:ObjectProperty rdf:about="https://example.org/roadsigns#hasBackgroundColour">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#RoadSign"/>
        <rdfs:range rdf:resource="https://example.org/roadsigns#Colour"/>
        <rdfs:comment xml:lang="en">The background/ground colour of the sign panel.</rdfs:comment>
        <rdfs:label xml:lang="en">Has background colour</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/roadsigns#hasBorderColour -->

    <owl:ObjectProperty rdf:about="https://example.org/roadsigns#hasBorderColour">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#RoadSign"/>
        <rdfs:range rdf:resource="https://example.org/roadsigns#Colour"/>
        <rdfs:comment xml:lang="en">The border colour of the sign panel.</rdfs:comment>
        <rdfs:label xml:lang="en">Has border colour</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/roadsigns#hasObject -->

    <owl:ObjectProperty rdf:about="https://example.org/roadsigns#hasObject">
        <rdfs:subPropertyOf rdf:resource="https://example.org/roadsigns#depictsObject"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:comment xml:lang="en">Links a specific Bounding Box instance to the specific sign detected.</rdfs:comment>
        <rdfs:label xml:lang="en">MSTD Dataset Mapping</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/roadsigns#hasShape -->

    <owl:ObjectProperty rdf:about="https://example.org/roadsigns#hasShape">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#RoadSign"/>
        <rdfs:range rdf:resource="https://example.org/roadsigns#Shape"/>
        <rdfs:comment xml:lang="en">Associates a road sign with its geometric shape. Functional: each sign has exactly one shape.</rdfs:comment>
        <rdfs:label xml:lang="en">Has shape</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/roadsigns#hasSymbol -->

    <owl:ObjectProperty rdf:about="https://example.org/roadsigns#hasSymbol">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#RoadSign"/>
        <rdfs:range rdf:resource="https://example.org/roadsigns#SymbolRoadSign"/>
        <rdfs:comment xml:lang="en">Associates a sign with one or more symbols/pictograms it displays.</rdfs:comment>
        <rdfs:label xml:lang="en">Has symbol</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/roadsigns#hasSymbolColour -->

    <owl:ObjectProperty rdf:about="https://example.org/roadsigns#hasSymbolColour">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#RoadSign"/>
        <rdfs:range rdf:resource="https://example.org/roadsigns#Colour"/>
        <rdfs:comment xml:lang="en">The colour of the symbol drawn on a sign.</rdfs:comment>
        <rdfs:label xml:lang="en">Has symbol colour</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://example.org/roadsigns#isLabeledAs -->

    <owl:ObjectProperty rdf:about="https://example.org/roadsigns#isLabeledAs">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#RoadSign"/>
        <rdfs:range rdf:resource="https://example.org/roadsigns#MTSD_Label"/>
        <rdfs:comment xml:lang="en">Maps the convention-based sign to its specific MTSD dataset label.</rdfs:comment>
        <rdfs:label xml:lang="en">Is labeled as</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://example.org/roadsigns#hasHeightLimitValue -->

    <owl:DatatypeProperty rdf:about="https://example.org/roadsigns#hasHeightLimitValue">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#HeightRestrictionWarningSign"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">The numerical value representing the maximum permissible vehicle height, typically in meters, as shown on the sign.</rdfs:comment>
        <rdfs:label xml:lang="en">Has height limit value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/roadsigns#hasMTSDLabel -->

    <owl:DatatypeProperty rdf:about="https://example.org/roadsigns#hasMTSDLabel">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#RoadSign"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The Mapillary Traffic Sign Dataset class label string (e.g. &quot;regulatory--keep-right--g1&quot;).</rdfs:comment>
        <rdfs:label xml:lang="en">Has MTSD label</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/roadsigns#hasModel -->

    <owl:DatatypeProperty rdf:about="https://example.org/roadsigns#hasModel">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#RoadSign"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The official Vienna Convention model code of the sign (e.g. &quot;B2a&quot;, &quot;A7&quot;, &quot;C14&quot;).</rdfs:comment>
        <rdfs:label xml:lang="en">Has model</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/roadsigns#hasNormalSideLength -->

    <owl:DatatypeProperty rdf:about="https://example.org/roadsigns#hasNormalSideLength">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#RoadSign"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">The standard measurement for the side or diameter of a sign in metres, as defined by the Vienna Convention.</rdfs:comment>
        <rdfs:label xml:lang="en">Has normal side length (m)</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/roadsigns#hasSpeedLimitValue -->

    <owl:DatatypeProperty rdf:about="https://example.org/roadsigns#hasSpeedLimitValue">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#MaximumSpeedLimitSign"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">The numerical value representing the maximum or minimum speed limit allowed (km/h), as indicated on a speed limit sign.</rdfs:comment>
        <rdfs:label xml:lang="en">Has speed limit value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/roadsigns#hasTextContent -->

    <owl:DatatypeProperty rdf:about="https://example.org/roadsigns#hasTextContent">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#RoadSign"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The literal textual string displayed on the road sign, used for city names, supplementary instructions, or street names.</rdfs:comment>
        <rdfs:label xml:lang="en">Has text content</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/roadsigns#hasWeightLimitValue -->

    <owl:DatatypeProperty rdf:about="https://example.org/roadsigns#hasWeightLimitValue">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#WeightLimitSign"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">The numerical value representing the maximum permissible vehicle weight or axle load, typically in tonnes.</rdfs:comment>
        <rdfs:label xml:lang="en">Has weight limit value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/roadsigns#imageHeight -->

    <owl:DatatypeProperty rdf:about="https://example.org/roadsigns#imageHeight">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#Image"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">The total vertical dimension of the source image, measured in pixels.</rdfs:comment>
        <rdfs:label xml:lang="en">Image height (px)</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/roadsigns#imageWidth -->

    <owl:DatatypeProperty rdf:about="https://example.org/roadsigns#imageWidth">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#Image"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">The total horizontal dimension of the source image, measured in pixels.</rdfs:comment>
        <rdfs:label xml:lang="en">Image width (px)</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/roadsigns#isAmbiguous -->

    <owl:DatatypeProperty rdf:about="https://example.org/roadsigns#isAmbiguous">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#TrafficSignObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label xml:lang="en">Is ambiguous</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/roadsigns#isHighway -->

    <owl:DatatypeProperty rdf:about="https://example.org/roadsigns#isHighway">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#TrafficSignObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label xml:lang="en">Is highway sign</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/roadsigns#isOccluded -->

    <owl:DatatypeProperty rdf:about="https://example.org/roadsigns#isOccluded">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#TrafficSignObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">A boolean flag indicating whether the road sign is partially blocked or obscured by another object in the image.</rdfs:comment>
        <rdfs:label xml:lang="en">Is occluded</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/roadsigns#isOutOfFrame -->

    <owl:DatatypeProperty rdf:about="https://example.org/roadsigns#isOutOfFrame">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#TrafficSignObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label xml:lang="en">Is out of frame</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/roadsigns#isPanorama -->

    <owl:DatatypeProperty rdf:about="https://example.org/roadsigns#isPanorama">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#Image"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label xml:lang="en">Is panorama</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/roadsigns#objectKey -->

    <owl:DatatypeProperty rdf:about="https://example.org/roadsigns#objectKey">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#TrafficSignObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A unique alphanumeric identifier assigned to a specific road sign instance or detection within the dataset.</rdfs:comment>
        <rdfs:label xml:lang="en">Object key</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/roadsigns#sourceFile -->

    <owl:DatatypeProperty rdf:about="https://example.org/roadsigns#sourceFile">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#Image"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The filename or path of the original image source file where the sign detection was found.</rdfs:comment>
        <rdfs:label xml:lang="en">Source file</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/roadsigns#xmax -->

    <owl:DatatypeProperty rdf:about="https://example.org/roadsigns#xmax">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#TrafficSignObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">The maximum x-coordinate (right side) of the bounding box for a detected road sign object within an image.</rdfs:comment>
        <rdfs:label xml:lang="en">Bounding box x-max</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/roadsigns#xmin -->

    <owl:DatatypeProperty rdf:about="https://example.org/roadsigns#xmin">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#TrafficSignObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">The minimum x-coordinate (left side) of the bounding box for a detected road sign sign object within an image.</rdfs:comment>
        <rdfs:label xml:lang="en">Bounding box x-min</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/roadsigns#ymax -->

    <owl:DatatypeProperty rdf:about="https://example.org/roadsigns#ymax">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#TrafficSignObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">The maximum y-coordinate (bottom side) of the bounding box for a detected road sign object within an image.</rdfs:comment>
        <rdfs:label xml:lang="en">Bounding box y-max</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://example.org/roadsigns#ymin -->

    <owl:DatatypeProperty rdf:about="https://example.org/roadsigns#ymin">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://example.org/roadsigns#TrafficSignObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">The minimum y-coordinate (top side) of the bounding box for a detected road sign object within an image.</rdfs:comment>
        <rdfs:label xml:lang="en">Bounding box y-min</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://example.org/roadsigns#AccessProhibitorySign -->

    <owl:Class rdf:about="https://example.org/roadsigns#AccessProhibitorySign">
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#ProhibitorySign"/>
    </owl:Class>
    


    <!-- https://example.org/roadsigns#AccidentAreaComplementarySign -->

    <owl:Class rdf:about="https://example.org/roadsigns#AccidentAreaComplementarySign">
        <owl:equivalentClass rdf:resource="https://example.org/roadsigns#complementary--accident-area--g3"/>
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#AreaExtentComplementarySign"/>
    </owl:Class>
    


    <!-- https://example.org/roadsigns#AccidentAreaWarningSign -->

    <owl:Class rdf:about="https://example.org/roadsigns#AccidentAreaWarningSign">
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#OtherDangerWarningSign"/>
    </owl:Class>
    


    <!-- https://example.org/roadsigns#AddedLaneRightWarningSign -->

    <owl:Class rdf:about="https://example.org/roadsigns#AddedLaneRightWarningSign">
        <owl:equivalentClass rdf:resource="https://example.org/roadsigns#warning--added-lane-right--g1"/>
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#OtherRoadHazardSign"/>
    </owl:Class>
    


    <!-- https://example.org/roadsigns#AirportSign -->

    <owl:Class rdf:about="https://example.org/roadsigns#AirportSign">
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#OtherDirectionInformationSign"/>
    </owl:Class>
    


    <!-- https://example.org/roadsigns#AnimalCrossingWarningSign -->

    <owl:Class rdf:about="https://example.org/roadsigns#AnimalCrossingWarningSign">
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#AnimalHazardSign"/>
        <rdfs:comment xml:lang="en">A14/A15: warns of wild or domestic animals crossing.</rdfs:comment>
        <rdfs:label xml:lang="en">Animal Crossing Warning Sign</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/roadsigns#AnimalHazardSign -->

    <owl:Class rdf:about="https://example.org/roadsigns#AnimalHazardSign">
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#DangerWarningSign"/>
    </owl:Class>
    


    <!-- https://example.org/roadsigns#AnimalSymbol -->

    <owl:Class rdf:about="https://example.org/roadsigns#AnimalSymbol">
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#SymbolRoadSign"/>
    </owl:Class>
    


    <!-- https://example.org/roadsigns#AreaExtentComplementarySign -->

    <owl:Class rdf:about="https://example.org/roadsigns#AreaExtentComplementarySign">
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#ComplementarySign"/>
    </owl:Class>
    


    <!-- https://example.org/roadsigns#AxleWeightLimitSign -->


    <!-- https://example.org/roadsigns#CompulsoryCycleTrack_D9a -->

    <owl:Class rdf:about="https://example.org/roadsigns#CompulsoryCycleTrack_D9a">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://example.org/roadsigns#RoadSign"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/roadsigns#hasSymbol"/>
                        <owl:someValuesFrom rdf:resource="https://example.org/roadsigns#BicycleSymbol"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/roadsigns#hasBackgroundColour"/>
                        <owl:hasValue rdf:resource="https://example.org/roadsigns#Blue"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/roadsigns#hasBorderColour"/>
                        <owl:hasValue rdf:resource="https://example.org/roadsigns#White"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/roadsigns#hasShape"/>
                        <owl:hasValue rdf:resource="https://example.org/roadsigns#Circle"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/roadsigns#hasSymbolColour"/>
                        <owl:hasValue rdf:resource="https://example.org/roadsigns#White"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#CompulsoryCycleTrackSign"/>
    </owl:Class>
    



        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#RoadSign"/>
        <rdfs:comment xml:lang="en">Section B of the Vienna Convention. Signs that establish priority at intersections or road sections.</rdfs:comment>
        <rdfs:label xml:lang="en">Priority Sign</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/roadsigns#ProhibitorySign -->

    <owl:Class rdf:about="https://example.org/roadsigns#ProhibitorySign">
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#RoadSign"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/roadsigns#hasBorderColour"/>
                <owl:hasValue rdf:resource="https://example.org/roadsigns#Red"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/roadsigns#hasShape"/>
                <owl:hasValue rdf:resource="https://example.org/roadsigns#Circle"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Section C of the Vienna Convention. Circular signs that prohibit certain actions or vehicles. White/yellow background, red border, symbol in black (unless otherwise specified).</rdfs:comment>
        <rdfs:label xml:lang="en">Prohibitory Sign</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/roadsigns#RadarEnforcedSign -->

    <owl:Class rdf:about="https://example.org/roadsigns#RadarEnforcedSign">
        <owl:equivalentClass rdf:resource="https://example.org/roadsigns#regulatory--radar-enforced--g1"/>

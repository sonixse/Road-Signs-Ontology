    <!-- https://example.org/roadsigns#MandatorySign -->

    <owl:Class rdf:about="https://example.org/roadsigns#MandatorySign">
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#RoadSign"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/roadsigns#hasBackgroundColour"/>
                <owl:hasValue rdf:resource="https://example.org/roadsigns#Blue"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://example.org/roadsigns#hasShape"/>
                <owl:hasValue rdf:resource="https://example.org/roadsigns#Circle"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Section D of the Vienna Convention. Circular blue signs with white symbols that prescribe an obligation for road users.</rdfs:comment>
        <rdfs:label xml:lang="en">Mandatory Sign</rdfs:label>
    </owl:Class>
    



                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://example.org/roadsigns#RoadSign"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/roadsigns#hasSymbol"/>
                        <owl:someValuesFrom rdf:resource="https://example.org/roadsigns#CarSymbol"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/roadsigns#hasBackgroundColour"/>
                        <owl:hasValue rdf:resource="https://example.org/roadsigns#White"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/roadsigns#hasBorderColour"/>
                        <owl:hasValue rdf:resource="https://example.org/roadsigns#Red"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/roadsigns#hasShape"/>
                        <owl:hasValue rdf:resource="https://example.org/roadsigns#Circle"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/roadsigns#hasSymbolColour"/>
                        <owl:hasValue rdf:resource="https://example.org/roadsigns#Black"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://example.org/roadsigns#hasSymbolColour"/>
                        <owl:hasValue rdf:resource="https://example.org/roadsigns#Red"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#MovementProhibitorySign"/>
        <rdfs:comment xml:lang="en">C16: prohibits overtaking for all motor vehicles.</rdfs:comment>
        <rdfs:label xml:lang="en">No Overtaking Sign</rdfs:label>
    </owl:Class>
    



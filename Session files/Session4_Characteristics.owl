                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://example.org/roadsigns#SpeedProhibitorySign"/>
        <rdfs:comment xml:lang="en">C14: circular sign limiting maximum speed. Number in black on white, red border.</rdfs:comment>

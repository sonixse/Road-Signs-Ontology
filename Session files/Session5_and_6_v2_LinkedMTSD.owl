EquivalentClasses(roadsigns:SlipperyRoad_A9 ObjectIntersectionOf(roadsigns:RoadSurfaceHazardSign ObjectHasValue(roadsigns:hasBackgroundColour roadsigns:White) ObjectHasValue(roadsigns:hasBorderColour roadsigns:Red) ObjectHasValue(roadsigns:hasShape roadsigns:Triangle) DataHasValue(roadsigns:hasModel "A9") DataHasValue(roadsigns:hasNormalSideLength "0.90"^^xsd:decimal)))
SubClassOf(roadsigns:SlipperyRoad_A9 roadsigns:SlipperyRoadSign)


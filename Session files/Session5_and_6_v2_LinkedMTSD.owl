AnnotationAssertion(rdfs:label roadsigns:PriorityIntersectionRightSign "Priority Intersection (Right) Sign"@en)
SubClassOf(roadsigns:PriorityIntersectionRightSign roadsigns:PriorityIntersectionSign)

# Class: roadsigns:PriorityIntersectionSign (Priority Intersection Sign)

AnnotationAssertion(rdfs:comment roadsigns:PriorityIntersectionSign "P-1 (Spanish RGC): parent class for warning signs informing the driver, while travelling on a priority road, of an intersection with a subordinate (non-priority) road ahead. Triangular sign with red border (inherits the Triangle shape from DangerWarningSign). Depicts only the road-geometry diagram — carries no pictogram/symbol."@en)
AnnotationAssertion(rdfs:label roadsigns:PriorityIntersectionSign "Priority Intersection Sign"@en)
SubClassOf(roadsigns:PriorityIntersectionSign roadsigns:IntersectionWarningSign)
SubClassOf(roadsigns:PriorityIntersectionSign ObjectMaxCardinality(0 roadsigns:hasSymbol roadsigns:SymbolRoadSign))

# Class: roadsigns:PriorityMergeFromLeftSign (Priority Merge From Left Sign)

AnnotationAssertion(rdfs:comment roadsigns:PriorityMergeFromLeftSign "P-1d: warns drivers on a priority road of a subordinate road merging from the left at an acute (oblique) angle."@en)
AnnotationAssertion(rdfs:label roadsigns:PriorityMergeFromLeftSign "Priority Merge From Left Sign"@en)
SubClassOf(roadsigns:PriorityMergeFromLeftSign roadsigns:PriorityIntersectionSign)

# Class: roadsigns:PriorityMergeFromRightSign (Priority Merge From Right Sign)


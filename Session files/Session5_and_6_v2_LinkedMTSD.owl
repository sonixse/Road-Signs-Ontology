AnnotationAssertion(rdfs:comment roadsigns:PriorityRoadSign_B3 "B3: indicates the road on which drivers have priority (diamond shape, yellow/white with black border). Carries no pictogram."@en)
AnnotationAssertion(rdfs:label roadsigns:PriorityRoadSign_B3 "Priority Road Sign (B3)"@en)
EquivalentClasses(roadsigns:PriorityRoadSign_B3 ObjectIntersectionOf(roadsigns:RightOfWayPrioritySign ObjectHasValue(roadsigns:hasBackgroundColour roadsigns:Yellow) ObjectHasValue(roadsigns:hasBorderColour roadsigns:Black) ObjectHasValue(roadsigns:hasShape roadsigns:Diamond) DataHasValue(roadsigns:hasModel "B3")))
SubClassOf(roadsigns:PriorityRoadSign_B3 roadsigns:RightOfWayPrioritySign)
SubClassOf(roadsigns:PriorityRoadSign_B3 ObjectMaxCardinality(0 roadsigns:hasSymbol roadsigns:SymbolRoadSign))


AnnotationAssertion(rdfs:label roadsigns:PriorityOverOncomingTrafficSign "Priority Over Oncoming Traffic Sign"@en)
SubClassOf(roadsigns:PriorityOverOncomingTrafficSign roadsigns:PrioritySign)


# Object Property: roadsigns:appliesTo (Applies to)

AnnotationAssertion(rdfs:comment roadsigns:appliesTo "Indicates which category of road user is subject to this sign."@en)
AnnotationAssertion(rdfs:label roadsigns:appliesTo "Applies to"@en)
AsymmetricObjectProperty(roadsigns:appliesTo)
IrreflexiveObjectProperty(roadsigns:appliesTo)
ObjectPropertyDomain(roadsigns:appliesTo roadsigns:RoadSign)
ObjectPropertyRange(roadsigns:appliesTo roadsigns:RoadUser)

# Object Property: roadsigns:classifiedAs (Classified as)

AnnotationAssertion(rdfs:comment roadsigns:classifiedAs "Maps a raw detection to its formal semantic class.
Links a MTSD traffic sign object annotation to its corresponding ontology class."@en)
AnnotationAssertion(rdfs:label roadsigns:classifiedAs "Classified as"@en)
FunctionalObjectProperty(roadsigns:classifiedAs)
AsymmetricObjectProperty(roadsigns:classifiedAs)
IrreflexiveObjectProperty(roadsigns:classifiedAs)
ObjectPropertyDomain(roadsigns:classifiedAs roadsigns:TrafficSignObject)
ObjectPropertyRange(roadsigns:classifiedAs roadsigns:RoadSign)

# Object Property: roadsigns:depictsObject (Vienna Convention Mapping)

AnnotationAssertion(rdfs:comment roadsigns:depictsObject "Links an image to the abstract concept of a sign."@en)
AnnotationAssertion(rdfs:label roadsigns:depictsObject "Vienna Convention Mapping"@en)
AsymmetricObjectProperty(roadsigns:depictsObject)
IrreflexiveObjectProperty(roadsigns:depictsObject)
ObjectPropertyDomain(roadsigns:depictsObject roadsigns:Image)
ObjectPropertyRange(roadsigns:depictsObject roadsigns:TrafficSignObject)

# Object Property: roadsigns:hasBackgroundColour (Has background colour)

AnnotationAssertion(rdfs:comment roadsigns:hasBackgroundColour "The background/ground colour of the sign panel."@en)
AnnotationAssertion(rdfs:label roadsigns:hasBackgroundColour "Has background colour"@en)
FunctionalObjectProperty(roadsigns:hasBackgroundColour)
AsymmetricObjectProperty(roadsigns:hasBackgroundColour)
IrreflexiveObjectProperty(roadsigns:hasBackgroundColour)
ObjectPropertyDomain(roadsigns:hasBackgroundColour roadsigns:RoadSign)
ObjectPropertyRange(roadsigns:hasBackgroundColour roadsigns:Colour)

# Object Property: roadsigns:hasBorderColour (Has border colour)

AnnotationAssertion(rdfs:comment roadsigns:hasBorderColour "The border colour of the sign panel."@en)
AnnotationAssertion(rdfs:label roadsigns:hasBorderColour "Has border colour"@en)
FunctionalObjectProperty(roadsigns:hasBorderColour)
AsymmetricObjectProperty(roadsigns:hasBorderColour)
IrreflexiveObjectProperty(roadsigns:hasBorderColour)
ObjectPropertyDomain(roadsigns:hasBorderColour roadsigns:RoadSign)
ObjectPropertyRange(roadsigns:hasBorderColour roadsigns:Colour)

# Object Property: roadsigns:hasObject (MSTD Dataset Mapping)

AnnotationAssertion(rdfs:comment roadsigns:hasObject "Links a specific Bounding Box instance to the specific sign detected."@en)
AnnotationAssertion(rdfs:label roadsigns:hasObject "MSTD Dataset Mapping"@en)
SubObjectPropertyOf(roadsigns:hasObject roadsigns:depictsObject)
FunctionalObjectProperty(roadsigns:hasObject)
AsymmetricObjectProperty(roadsigns:hasObject)
IrreflexiveObjectProperty(roadsigns:hasObject)

# Object Property: roadsigns:hasShape (Has shape)

AnnotationAssertion(rdfs:comment roadsigns:hasShape "Associates a road sign with its geometric shape. Functional: each sign has exactly one shape."@en)
AnnotationAssertion(rdfs:label roadsigns:hasShape "Has shape"@en)
FunctionalObjectProperty(roadsigns:hasShape)
AsymmetricObjectProperty(roadsigns:hasShape)
IrreflexiveObjectProperty(roadsigns:hasShape)
ObjectPropertyDomain(roadsigns:hasShape roadsigns:RoadSign)
ObjectPropertyRange(roadsigns:hasShape roadsigns:Shape)

# Object Property: roadsigns:hasSymbol (Has symbol)

AnnotationAssertion(rdfs:comment roadsigns:hasSymbol "Associates a sign with one or more symbols/pictograms it displays."@en)
AnnotationAssertion(rdfs:label roadsigns:hasSymbol "Has symbol"@en)
AsymmetricObjectProperty(roadsigns:hasSymbol)
IrreflexiveObjectProperty(roadsigns:hasSymbol)
ObjectPropertyDomain(roadsigns:hasSymbol roadsigns:RoadSign)
ObjectPropertyRange(roadsigns:hasSymbol roadsigns:SymbolRoadSign)

# Object Property: roadsigns:hasSymbolColour (Has symbol colour)

AnnotationAssertion(rdfs:comment roadsigns:hasSymbolColour "The colour of the symbol drawn on a sign."@en)
AnnotationAssertion(rdfs:label roadsigns:hasSymbolColour "Has symbol colour"@en)
FunctionalObjectProperty(roadsigns:hasSymbolColour)
AsymmetricObjectProperty(roadsigns:hasSymbolColour)
IrreflexiveObjectProperty(roadsigns:hasSymbolColour)
ObjectPropertyDomain(roadsigns:hasSymbolColour roadsigns:RoadSign)
ObjectPropertyRange(roadsigns:hasSymbolColour roadsigns:Colour)

# Object Property: roadsigns:isLabeledAs (Is labeled as)

AnnotationAssertion(rdfs:comment roadsigns:isLabeledAs "Maps the convention-based sign to its specific MTSD dataset label."@en)
AnnotationAssertion(rdfs:label roadsigns:isLabeledAs "Is labeled as"@en)
FunctionalObjectProperty(roadsigns:isLabeledAs)
AsymmetricObjectProperty(roadsigns:isLabeledAs)
IrreflexiveObjectProperty(roadsigns:isLabeledAs)
ObjectPropertyDomain(roadsigns:isLabeledAs roadsigns:RoadSign)
ObjectPropertyRange(roadsigns:isLabeledAs roadsigns:MTSD_Label)


############################
#   Data Properties
############################

# Data Property: roadsigns:hasHeightLimitValue (Has height limit value)

AnnotationAssertion(rdfs:comment roadsigns:hasHeightLimitValue "The numerical value representing the maximum permissible vehicle height, typically in meters, as shown on the sign."@en)
AnnotationAssertion(rdfs:label roadsigns:hasHeightLimitValue "Has height limit value"@en)
FunctionalDataProperty(roadsigns:hasHeightLimitValue)
DataPropertyDomain(roadsigns:hasHeightLimitValue roadsigns:HeightRestrictionWarningSign)
DataPropertyRange(roadsigns:hasHeightLimitValue xsd:decimal)

# Data Property: roadsigns:hasMTSDLabel (Has MTSD label)

AnnotationAssertion(rdfs:comment roadsigns:hasMTSDLabel "The Mapillary Traffic Sign Dataset class label string (e.g. \"regulatory--keep-right--g1\")."@en)
AnnotationAssertion(rdfs:label roadsigns:hasMTSDLabel "Has MTSD label"@en)
FunctionalDataProperty(roadsigns:hasMTSDLabel)
DataPropertyDomain(roadsigns:hasMTSDLabel roadsigns:RoadSign)
DataPropertyRange(roadsigns:hasMTSDLabel xsd:string)

# Data Property: roadsigns:hasModel (Has model)

AnnotationAssertion(rdfs:comment roadsigns:hasModel "The official Vienna Convention model code of the sign (e.g. \"B2a\", \"A7\", \"C14\")."@en)
AnnotationAssertion(rdfs:label roadsigns:hasModel "Has model"@en)
FunctionalDataProperty(roadsigns:hasModel)
DataPropertyDomain(roadsigns:hasModel roadsigns:RoadSign)
DataPropertyRange(roadsigns:hasModel xsd:string)

# Data Property: roadsigns:hasNormalSideLength (Has normal side length (m))

AnnotationAssertion(rdfs:comment roadsigns:hasNormalSideLength "The standard measurement for the side or diameter of a sign in metres, as defined by the Vienna Convention."@en)
AnnotationAssertion(rdfs:label roadsigns:hasNormalSideLength "Has normal side length (m)"@en)
FunctionalDataProperty(roadsigns:hasNormalSideLength)
DataPropertyDomain(roadsigns:hasNormalSideLength roadsigns:RoadSign)
DataPropertyRange(roadsigns:hasNormalSideLength xsd:decimal)

# Data Property: roadsigns:hasSpeedLimitValue (Has speed limit value)

AnnotationAssertion(rdfs:comment roadsigns:hasSpeedLimitValue "The numerical value representing the maximum or minimum speed limit allowed (km/h), as indicated on a speed limit sign."@en)
AnnotationAssertion(rdfs:label roadsigns:hasSpeedLimitValue "Has speed limit value"@en)
FunctionalDataProperty(roadsigns:hasSpeedLimitValue)
DataPropertyDomain(roadsigns:hasSpeedLimitValue roadsigns:MaximumSpeedLimitSign)
DataPropertyRange(roadsigns:hasSpeedLimitValue xsd:integer)

# Data Property: roadsigns:hasTextContent (Has text content)

AnnotationAssertion(rdfs:comment roadsigns:hasTextContent "The literal textual string displayed on the road sign, used for city names, supplementary instructions, or street names."@en)
AnnotationAssertion(rdfs:label roadsigns:hasTextContent "Has text content"@en)
FunctionalDataProperty(roadsigns:hasTextContent)
DataPropertyDomain(roadsigns:hasTextContent roadsigns:RoadSign)
DataPropertyRange(roadsigns:hasTextContent xsd:string)

# Data Property: roadsigns:hasWeightLimitValue (Has weight limit value)

AnnotationAssertion(rdfs:comment roadsigns:hasWeightLimitValue "The numerical value representing the maximum permissible vehicle weight or axle load, typically in tonnes."@en)
AnnotationAssertion(rdfs:label roadsigns:hasWeightLimitValue "Has weight limit value"@en)
FunctionalDataProperty(roadsigns:hasWeightLimitValue)
DataPropertyDomain(roadsigns:hasWeightLimitValue roadsigns:WeightLimitSign)
DataPropertyRange(roadsigns:hasWeightLimitValue xsd:decimal)

# Data Property: roadsigns:imageHeight (Image height (px))

AnnotationAssertion(rdfs:comment roadsigns:imageHeight "The total vertical dimension of the source image, measured in pixels."@en)
AnnotationAssertion(rdfs:label roadsigns:imageHeight "Image height (px)"@en)
FunctionalDataProperty(roadsigns:imageHeight)
DataPropertyDomain(roadsigns:imageHeight roadsigns:Image)
DataPropertyRange(roadsigns:imageHeight xsd:integer)

# Data Property: roadsigns:imageWidth (Image width (px))

AnnotationAssertion(rdfs:comment roadsigns:imageWidth "The total horizontal dimension of the source image, measured in pixels."@en)
AnnotationAssertion(rdfs:label roadsigns:imageWidth "Image width (px)"@en)
FunctionalDataProperty(roadsigns:imageWidth)
DataPropertyDomain(roadsigns:imageWidth roadsigns:Image)
DataPropertyRange(roadsigns:imageWidth xsd:integer)

# Data Property: roadsigns:isAmbiguous (Is ambiguous)

AnnotationAssertion(rdfs:label roadsigns:isAmbiguous "Is ambiguous"@en)
FunctionalDataProperty(roadsigns:isAmbiguous)
DataPropertyDomain(roadsigns:isAmbiguous roadsigns:TrafficSignObject)
DataPropertyRange(roadsigns:isAmbiguous xsd:boolean)

# Data Property: roadsigns:isHighway (Is highway sign)

AnnotationAssertion(rdfs:label roadsigns:isHighway "Is highway sign"@en)
FunctionalDataProperty(roadsigns:isHighway)
DataPropertyDomain(roadsigns:isHighway roadsigns:TrafficSignObject)
DataPropertyRange(roadsigns:isHighway xsd:boolean)

# Data Property: roadsigns:isOccluded (Is occluded)

AnnotationAssertion(rdfs:comment roadsigns:isOccluded "A boolean flag indicating whether the road sign is partially blocked or obscured by another object in the image."@en)
AnnotationAssertion(rdfs:label roadsigns:isOccluded "Is occluded"@en)
FunctionalDataProperty(roadsigns:isOccluded)
DataPropertyDomain(roadsigns:isOccluded roadsigns:TrafficSignObject)
DataPropertyRange(roadsigns:isOccluded xsd:boolean)

# Data Property: roadsigns:isOutOfFrame (Is out of frame)

AnnotationAssertion(rdfs:label roadsigns:isOutOfFrame "Is out of frame"@en)
FunctionalDataProperty(roadsigns:isOutOfFrame)
DataPropertyDomain(roadsigns:isOutOfFrame roadsigns:TrafficSignObject)
DataPropertyRange(roadsigns:isOutOfFrame xsd:boolean)

# Data Property: roadsigns:isPanorama (Is panorama)

AnnotationAssertion(rdfs:label roadsigns:isPanorama "Is panorama"@en)
FunctionalDataProperty(roadsigns:isPanorama)
DataPropertyDomain(roadsigns:isPanorama roadsigns:Image)
DataPropertyRange(roadsigns:isPanorama xsd:boolean)

# Data Property: roadsigns:objectKey (Object key)

AnnotationAssertion(rdfs:comment roadsigns:objectKey "A unique alphanumeric identifier assigned to a specific road sign instance or detection within the dataset."@en)
AnnotationAssertion(rdfs:label roadsigns:objectKey "Object key"@en)
FunctionalDataProperty(roadsigns:objectKey)
DataPropertyDomain(roadsigns:objectKey roadsigns:TrafficSignObject)
DataPropertyRange(roadsigns:objectKey xsd:string)

# Data Property: roadsigns:sourceFile (Source file)

AnnotationAssertion(rdfs:comment roadsigns:sourceFile "The filename or path of the original image source file where the sign detection was found."@en)
AnnotationAssertion(rdfs:label roadsigns:sourceFile "Source file"@en)
FunctionalDataProperty(roadsigns:sourceFile)
DataPropertyDomain(roadsigns:sourceFile roadsigns:Image)
DataPropertyRange(roadsigns:sourceFile xsd:string)

# Data Property: roadsigns:xmax (Bounding box x-max)

AnnotationAssertion(rdfs:comment roadsigns:xmax "The maximum x-coordinate (right side) of the bounding box for a detected road sign object within an image."@en)
AnnotationAssertion(rdfs:label roadsigns:xmax "Bounding box x-max"@en)
FunctionalDataProperty(roadsigns:xmax)
DataPropertyDomain(roadsigns:xmax roadsigns:TrafficSignObject)
DataPropertyRange(roadsigns:xmax xsd:decimal)

# Data Property: roadsigns:xmin (Bounding box x-min)

AnnotationAssertion(rdfs:comment roadsigns:xmin "The minimum x-coordinate (left side) of the bounding box for a detected road sign sign object within an image."@en)
AnnotationAssertion(rdfs:label roadsigns:xmin "Bounding box x-min"@en)
FunctionalDataProperty(roadsigns:xmin)
DataPropertyDomain(roadsigns:xmin roadsigns:TrafficSignObject)
DataPropertyRange(roadsigns:xmin xsd:decimal)

# Data Property: roadsigns:ymax (Bounding box y-max)

AnnotationAssertion(rdfs:comment roadsigns:ymax "The maximum y-coordinate (bottom side) of the bounding box for a detected road sign object within an image."@en)
AnnotationAssertion(rdfs:label roadsigns:ymax "Bounding box y-max"@en)
FunctionalDataProperty(roadsigns:ymax)
DataPropertyDomain(roadsigns:ymax roadsigns:TrafficSignObject)
DataPropertyRange(roadsigns:ymax xsd:decimal)

# Data Property: roadsigns:ymin (Bounding box y-min)

AnnotationAssertion(rdfs:comment roadsigns:ymin "The minimum y-coordinate (top side) of the bounding box for a detected road sign object within an image."@en)
AnnotationAssertion(rdfs:label roadsigns:ymin "Bounding box y-min"@en)
FunctionalDataProperty(roadsigns:ymin)
DataPropertyDomain(roadsigns:ymin roadsigns:TrafficSignObject)
DataPropertyRange(roadsigns:ymin xsd:decimal)



############################
#   Classes
############################

# Class: roadsigns:AccessProhibitorySign (roadsigns:AccessProhibitorySign)

SubClassOf(roadsigns:AccessProhibitorySign roadsigns:ProhibitorySign)

# Class: roadsigns:AccidentAreaComplementarySign (roadsigns:AccidentAreaComplementarySign)

EquivalentClasses(roadsigns:AccidentAreaComplementarySign roadsigns:complementary--accident-area--g3)
SubClassOf(roadsigns:AccidentAreaComplementarySign roadsigns:AreaExtentComplementarySign)

# Class: roadsigns:AccidentAreaWarningSign (Accident Area Warning Sign)

AnnotationAssertion(rdfs:comment roadsigns:AccidentAreaWarningSign "Warns of a traffic accident ahead (typically a dynamically activated VMS or temporary deployment)."@en)
AnnotationAssertion(rdfs:label roadsigns:AccidentAreaWarningSign "Accident Area Warning Sign"@en)
SubClassOf(roadsigns:AccidentAreaWarningSign roadsigns:OtherDangerWarningSign)

# Class: roadsigns:AddedLaneRightWarningSign (roadsigns:AddedLaneRightWarningSign)

EquivalentClasses(roadsigns:AddedLaneRightWarningSign roadsigns:warning--added-lane-right--g1)
SubClassOf(roadsigns:AddedLaneRightWarningSign roadsigns:OtherRoadHazardSign)

# Class: roadsigns:AirportSign (roadsigns:AirportSign)

SubClassOf(roadsigns:AirportSign roadsigns:OtherDirectionInformationSign)

# Class: roadsigns:AirportWarningSign (Airport Warning Sign)

AnnotationAssertion(rdfs:comment roadsigns:AirportWarningSign "Spanish RGC P-12: warns of low-flying aircraft near an airport / aerodrome. Distinct from AirportSign which is an OtherDirectionInformationSign pointing to an airport."@en)
AnnotationAssertion(rdfs:label roadsigns:AirportWarningSign "Airport Warning Sign"@en)
AnnotationAssertion(rdfs:label roadsigns:AirportWarningSign "P-12 Aeropuerto"@es)
SubClassOf(roadsigns:AirportWarningSign roadsigns:OtherDangerWarningSign)

# Class: roadsigns:AnimalCrossingWarningSign (Animal Crossing Warning Sign)

AnnotationAssertion(rdfs:comment roadsigns:AnimalCrossingWarningSign "Parent class for animal-crossing warnings (DomesticAnimalCrossingSign + WildAnimalCrossingSign)."@en)
AnnotationAssertion(rdfs:label roadsigns:AnimalCrossingWarningSign "Animal Crossing Warning Sign"@en)
SubClassOf(roadsigns:AnimalCrossingWarningSign roadsigns:AnimalHazardSign)

# Class: roadsigns:AnimalHazardSign (roadsigns:AnimalHazardSign)

SubClassOf(roadsigns:AnimalHazardSign roadsigns:DangerWarningSign)

# Class: roadsigns:AnimalSymbol (roadsigns:AnimalSymbol)

SubClassOf(roadsigns:AnimalSymbol roadsigns:SymbolRoadSign)

# Class: roadsigns:AreaExtentComplementarySign (roadsigns:AreaExtentComplementarySign)

SubClassOf(roadsigns:AreaExtentComplementarySign roadsigns:ComplementarySign)

# Class: roadsigns:AxleWeightLimitSign (Axle Weight Limit Sign)

AnnotationAssertion(rdfs:comment roadsigns:AxleWeightLimitSign "Restricts the maximum axle load permitted."@en)
AnnotationAssertion(rdfs:label roadsigns:AxleWeightLimitSign "Axle Weight Limit Sign"@en)
SubClassOf(roadsigns:AxleWeightLimitSign roadsigns:WeightLimitSign)

# Class: roadsigns:BicycleSymbol (roadsigns:BicycleSymbol)

SubClassOf(roadsigns:BicycleSymbol roadsigns:VehicleSymbol)

# Class: roadsigns:BicyclesCrossingWarningSign (roadsigns:BicyclesCrossingWarningSign)

SubClassOf(roadsigns:BicyclesCrossingWarningSign roadsigns:CyclistWarningSign)

# Class: roadsigns:BicyclesOnlySign (roadsigns:BicyclesOnlySign)

SubClassOf(roadsigns:BicyclesOnlySign roadsigns:CompulsoryCycleTrackSign)

# Class: roadsigns:BikeRouteSign (roadsigns:BikeRouteSign)

SubClassOf(roadsigns:BikeRouteSign roadsigns:CompulsoryCycleTrackSign)

# Class: roadsigns:BothDirectionsComplementarySign (roadsigns:BothDirectionsComplementarySign)

EquivalentClasses(roadsigns:BothDirectionsComplementarySign roadsigns:complementary--both-directions--g1)
SubClassOf(roadsigns:BothDirectionsComplementarySign roadsigns:DirectionalComplementarySign)

# Class: roadsigns:BuiltUpAreaSign (Built-Up Area Sign)

AnnotationAssertion(rdfs:comment roadsigns:BuiltUpAreaSign "E5/E6: marks the beginning/end of a built-up area (town entry/exit)."@en)
AnnotationAssertion(rdfs:label roadsigns:BuiltUpAreaSign "Built-Up Area Sign"@en)
SubClassOf(roadsigns:BuiltUpAreaSign roadsigns:ZoneRegulationSign)

# Class: roadsigns:BusDriver (Bus Driver)

AnnotationAssertion(rdfs:label roadsigns:BusDriver "Bus Driver"@en)
SubClassOf(roadsigns:BusDriver roadsigns:MotorVehicleDriver)

# Class: roadsigns:BusStopAheadWarningSign (roadsigns:BusStopAheadWarningSign)

EquivalentClasses(roadsigns:BusStopAheadWarningSign roadsigns:warning--bus-stop-ahead--g3)
SubClassOf(roadsigns:BusStopAheadWarningSign roadsigns:OtherRoadUserHazardSign)

# Class: roadsigns:BusStopSign (roadsigns:BusStopSign)

EquivalentClasses(roadsigns:BusStopSign roadsigns:information--bus-stop--g1)
SubClassOf(roadsigns:BusStopSign roadsigns:OtherCrossingInformationSign)

# Class: roadsigns:BusesComplementarySign (roadsigns:BusesComplementarySign)

EquivalentClasses(roadsigns:BusesComplementarySign roadsigns:complementary--buses--g1)
SubClassOf(roadsigns:BusesComplementarySign roadsigns:VehicleClassComplementarySign)

# Class: roadsigns:BusesOnlySign (roadsigns:BusesOnlySign)

EquivalentClasses(roadsigns:BusesOnlySign roadsigns:regulatory--buses-only--g1)
SubClassOf(roadsigns:BusesOnlySign roadsigns:CompulsoryBusLaneSign)

# Class: roadsigns:CampSign (roadsigns:CampSign)

EquivalentClasses(roadsigns:CampSign roadsigns:information--camp--g1)
SubClassOf(roadsigns:CampSign roadsigns:OtherServiceInformationSign)

# Class: roadsigns:CarSymbol (roadsigns:CarSymbol)

SubClassOf(roadsigns:CarSymbol roadsigns:VehicleSymbol)

# Class: roadsigns:CentralLaneSign (roadsigns:CentralLaneSign)

SubClassOf(roadsigns:CentralLaneSign roadsigns:OtherTrafficFlowRegulationSign)

# Class: roadsigns:ChevronLeftComplementarySign (roadsigns:ChevronLeftComplementarySign)

SubClassOf(roadsigns:ChevronLeftComplementarySign roadsigns:DirectionalComplementarySign)

# Class: roadsigns:ChevronRightComplementarySign (roadsigns:ChevronRightComplementarySign)

SubClassOf(roadsigns:ChevronRightComplementarySign roadsigns:DirectionalComplementarySign)

# Class: roadsigns:ChildrenWarningSign (Children Warning Sign)

AnnotationAssertion(rdfs:comment roadsigns:ChildrenWarningSign "Spanish RGC P-21 / Vienna A12: warns of children crossing or playing near the road."@en)
AnnotationAssertion(rdfs:label roadsigns:ChildrenWarningSign "Children Warning Sign"@en)
AnnotationAssertion(rdfs:label roadsigns:ChildrenWarningSign "P-21 Niños"@es)
SubClassOf(roadsigns:ChildrenWarningSign roadsigns:RoadUserHazardSign)

# Class: roadsigns:Colour (Colour)

AnnotationAssertion(rdfs:comment roadsigns:Colour "A colour used in road sign design (background, border, or symbol)."@en)
AnnotationAssertion(rdfs:label roadsigns:Colour "Colour"@en)

# Class: roadsigns:ComplementarySign (Complementary Sign)

AnnotationAssertion(rdfs:comment roadsigns:ComplementarySign "Not a Section in Vienna Convention but aligned with MSTD dataset."@en)
AnnotationAssertion(rdfs:label roadsigns:ComplementarySign "Complementary Sign"@en)
SubClassOf(roadsigns:ComplementarySign roadsigns:RoadSign)

# Class: roadsigns:CompulsoryBusLaneSign (roadsigns:CompulsoryBusLaneSign)

SubClassOf(roadsigns:CompulsoryBusLaneSign roadsigns:PathMandatorySign)

# Class: roadsigns:CompulsoryCycleTrackSign (roadsigns:CompulsoryCycleTrackSign)

SubClassOf(roadsigns:CompulsoryCycleTrackSign roadsigns:PathMandatorySign)

# Class: roadsigns:CompulsoryCycleTrack_D4 (roadsigns:CompulsoryCycleTrack_D4)

SubClassOf(roadsigns:CompulsoryCycleTrack_D4 roadsigns:CompulsoryCycleTrackSign)

# Class: roadsigns:CompulsoryFootpathSign (roadsigns:CompulsoryFootpathSign)

SubClassOf(roadsigns:CompulsoryFootpathSign roadsigns:PathMandatorySign)

# Class: roadsigns:CompulsoryFootpath_D5 (roadsigns:CompulsoryFootpath_D5)

SubClassOf(roadsigns:CompulsoryFootpath_D5 roadsigns:CompulsoryFootpathSign)

# Class: roadsigns:CrossingInformationSign (roadsigns:CrossingInformationSign)

SubClassOf(roadsigns:CrossingInformationSign roadsigns:InformationSign)

# Class: roadsigns:CrossroadsWarningSign (Crossroads Warning Sign)

AnnotationAssertion(rdfs:comment roadsigns:CrossroadsWarningSign "Warns of an intersection of two roads of equal priority ahead (no subordinate side road indicated)."@en)
AnnotationAssertion(rdfs:label roadsigns:CrossroadsWarningSign "Crossroads Warning Sign"@en)
SubClassOf(roadsigns:CrossroadsWarningSign roadsigns:IntersectionWarningSign)

# Class: roadsigns:CrosswindWarningSign (Crosswind Warning Sign)

AnnotationAssertion(rdfs:comment roadsigns:CrosswindWarningSign "Spanish RGC P-29: warns of a stretch of road exposed to strong lateral (cross) winds."@en)
AnnotationAssertion(rdfs:label roadsigns:CrosswindWarningSign "Crosswind Warning Sign"@en)
AnnotationAssertion(rdfs:label roadsigns:CrosswindWarningSign "P-29 Viento transversal"@es)
SubClassOf(roadsigns:CrosswindWarningSign roadsigns:GeographicalHazardSign)

# Class: roadsigns:CrossroadsWithPriorityToTheRightSign (Crossroads With Priority to the Right Sign)

AnnotationAssertion(rdfs:comment roadsigns:CrossroadsWithPriorityToTheRightSign "Warns of a crossroads where vehicles coming from the right have priority. Despite the priority semantics it is a warning sign (triangular, red border)."@en)
AnnotationAssertion(rdfs:label roadsigns:CrossroadsWithPriorityToTheRightSign "Crossroads With Priority to the Right Sign"@en)
EquivalentClasses(roadsigns:CrossroadsWithPriorityToTheRightSign roadsigns:warning--crossroads-with-priority-to-the-right--g1)
SubClassOf(roadsigns:CrossroadsWithPriorityToTheRightSign roadsigns:IntersectionWarningSign)

# Class: roadsigns:CurveLeftSign (roadsigns:CurveLeftSign)

SubClassOf(roadsigns:CurveLeftSign roadsigns:LeftBendSign)

# Class: roadsigns:CurveRightSign (roadsigns:CurveRightSign)

SubClassOf(roadsigns:CurveRightSign roadsigns:RightBendSign)

# Class: roadsigns:Cyclist (roadsigns:Cyclist)

SubClassOf(roadsigns:Cyclist roadsigns:RoadUser)

# Class: roadsigns:CyclistSymbol (roadsigns:CyclistSymbol)

SubClassOf(roadsigns:CyclistSymbol roadsigns:HumanSymbol)

# Class: roadsigns:CyclistWarningSign (Cyclist Warning Sign)

AnnotationAssertion(rdfs:comment roadsigns:CyclistWarningSign "Spanish RGC P-22: warns of cyclists entering or crossing."@en)
AnnotationAssertion(rdfs:label roadsigns:CyclistWarningSign "Cyclist Warning Sign"@en)
AnnotationAssertion(rdfs:label roadsigns:CyclistWarningSign "P-22 Ciclistas"@es)
SubClassOf(roadsigns:CyclistWarningSign roadsigns:RoadUserHazardSign)

# Class: roadsigns:DangerWarningSign (Danger Warning Sign)

AnnotationAssertion(rdfs:comment roadsigns:DangerWarningSign "Section A of the Vienna Convention. Triangular signs (Model A^a) or diamond-shaped signs (Model A^b) that warn of hazards ahead. Background white or yellow, border red."@en)
AnnotationAssertion(rdfs:label roadsigns:DangerWarningSign "Danger Warning Sign"@en)
SubClassOf(roadsigns:DangerWarningSign roadsigns:RoadSign)
SubClassOf(roadsigns:DangerWarningSign ObjectUnionOf(ObjectHasValue(roadsigns:hasShape roadsigns:Triangle) ObjectHasValue(roadsigns:hasShape roadsigns:Diamond)))

# Class: roadsigns:DangerousBendSign (Dangerous Bend or Bends Sign)

AnnotationAssertion(rdfs:comment roadsigns:DangerousBendSign "A1 series: warns of a dangerous bend or succession of bends ahead."@en)
AnnotationAssertion(rdfs:label roadsigns:DangerousBendSign "Dangerous Bend or Bends Sign"@en)
SubClassOf(roadsigns:DangerousBendSign roadsigns:RoadGeometryHazardSign)

# Class: roadsigns:DangerousDescentSign (Dangerous Descent Sign)

AnnotationAssertion(rdfs:comment roadsigns:DangerousDescentSign "Spanish RGC P-16a / Vienna A2: warns of a steep downhill gradient."@en)
AnnotationAssertion(rdfs:label roadsigns:DangerousDescentSign "Dangerous Descent Sign"@en)
AnnotationAssertion(rdfs:label roadsigns:DangerousDescentSign "P-16a Bajada con fuerte pendiente"@es)
SubClassOf(roadsigns:DangerousDescentSign roadsigns:RoadGeometryHazardSign)

# Class: roadsigns:DangerousShoulderWarningSign (Dangerous Shoulder Warning Sign)

AnnotationAssertion(rdfs:comment roadsigns:DangerousShoulderWarningSign "Spanish RGC P-30: warns of a lateral drop / hazardous shoulder along the carriageway edge."@en)

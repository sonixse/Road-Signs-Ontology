        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ChildrenWarningSign</IRI>
        <Literal xml:lang="es">P-21 Niños</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Colour</IRI>
        <Literal xml:lang="en">A colour used in road sign design (background, border, or symbol).</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Colour</IRI>
        <Literal xml:lang="en">Colour</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ComplementarySign</IRI>
        <Literal xml:lang="en">Not a Section in Vienna Convention but aligned with MSTD dataset.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ComplementarySign</IRI>
        <Literal xml:lang="en">Complementary Sign</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#CrossroadsWarningSign</IRI>
        <Literal xml:lang="en">Warns of an intersection of two roads of equal priority ahead (no subordinate side road indicated).</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#CrossroadsWarningSign</IRI>
        <Literal xml:lang="en">Crossroads Warning Sign</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#CrossroadsWithPriorityToTheRightSign</IRI>
        <Literal xml:lang="en">Warns of a crossroads where vehicles coming from the right have priority. Despite the priority semantics it is a warning sign (triangular, red border).</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#CrossroadsWithPriorityToTheRightSign</IRI>
        <Literal xml:lang="en">Crossroads With Priority to the Right Sign</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#CrosswindWarningSign</IRI>
        <Literal xml:lang="en">Spanish RGC P-29: warns of a stretch of road exposed to strong lateral (cross) winds.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#CrosswindWarningSign</IRI>
        <Literal xml:lang="en">Crosswind Warning Sign</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#CrosswindWarningSign</IRI>
        <Literal xml:lang="es">P-29 Viento transversal</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#CyclistWarningSign</IRI>
        <Literal xml:lang="en">Spanish RGC P-22: warns of cyclists entering or crossing.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#CyclistWarningSign</IRI>

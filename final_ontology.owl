    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#CyclistWarningSign</IRI>
        <Literal xml:lang="es">P-22 Ciclistas</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#DangerWarningSign</IRI>
        <Literal xml:lang="en">Section A of the Vienna Convention. Triangular signs (Model A^a) or diamond-shaped signs (Model A^b) that warn of hazards ahead. Background white or yellow, border red.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#DangerWarningSign</IRI>
        <Literal xml:lang="en">Danger Warning Sign</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#DangerousBendSign</IRI>
        <Literal xml:lang="en">A1 series: warns of a dangerous bend or succession of bends ahead.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#DangerousBendSign</IRI>
        <Literal xml:lang="en">Dangerous Bend or Bends Sign</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#DangerousDescentSign</IRI>
        <Literal xml:lang="en">Spanish RGC P-16a / Vienna A2: warns of a steep downhill gradient.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#DangerousDescentSign</IRI>
        <Literal xml:lang="en">Dangerous Descent Sign</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#DangerousDescentSign</IRI>
        <Literal xml:lang="es">P-16a Bajada con fuerte pendiente</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#DangerousShoulderWarningSign</IRI>
        <Literal xml:lang="en">Spanish RGC P-30: warns of a lateral drop / hazardous shoulder along the carriageway edge.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#DangerousShoulderWarningSign</IRI>
        <Literal xml:lang="en">Dangerous Shoulder Warning Sign</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#DangerousShoulderWarningSign</IRI>
        <Literal xml:lang="es">P-30 Escalón lateral</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#DeadEndSign</IRI>
        <Literal xml:lang="en">E12: indicates a dead-end road with no through route.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#DeadEndSign</IRI>
        <Literal xml:lang="en">Dead End Sign</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#DipSign</IRI>

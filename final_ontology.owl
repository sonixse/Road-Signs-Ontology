        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#AirportWarningSign</IRI>
        <Literal xml:lang="es">P-12 Aeropuerto</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#AnimalCrossingWarningSign</IRI>
        <Literal xml:lang="en">Parent class for animal-crossing warnings (DomesticAnimalCrossingSign + WildAnimalCrossingSign).</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#AnimalCrossingWarningSign</IRI>
        <Literal xml:lang="en">Animal Crossing Warning Sign</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>

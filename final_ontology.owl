        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#AxleWeightLimitSign</IRI>
        <Literal xml:lang="en">Axle Weight Limit Sign</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#BuiltUpAreaSign</IRI>
        <Literal xml:lang="en">E5/E6: marks the beginning/end of a built-up area (town entry/exit).</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#BuiltUpAreaSign</IRI>
        <Literal xml:lang="en">Built-Up Area Sign</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#BusDriver</IRI>
        <Literal xml:lang="en">Bus Driver</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ChildrenWarningSign</IRI>
        <Literal xml:lang="en">Spanish RGC P-21 / Vienna A12: warns of children crossing or playing near the road.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ChildrenWarningSign</IRI>

    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#AccidentAreaWarningSign</IRI>
        <Literal xml:lang="en">Warns of a traffic accident ahead (typically a dynamically activated VMS or temporary deployment).</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#AccidentAreaWarningSign</IRI>
        <Literal xml:lang="en">Accident Area Warning Sign</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#AirportWarningSign</IRI>
        <Literal xml:lang="en">Spanish RGC P-12: warns of low-flying aircraft near an airport / aerodrome. Distinct from AirportSign which is an OtherDirectionInformationSign pointing to an airport.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#AirportWarningSign</IRI>
        <Literal xml:lang="en">Airport Warning Sign</Literal>
    </AnnotationAssertion>
